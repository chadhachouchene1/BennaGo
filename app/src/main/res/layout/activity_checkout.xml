<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_login_hero"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#E1D4C2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📦  Valider la commande"
                android:textColor="#E1D4C2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View android:layout_width="40dp" android:layout_height="40dp"/>
        </LinearLayout>

        <!-- CARTE : Récapitulatif -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋  Récapitulatif"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#291C0E"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_checkout_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="13sp"
                    android:textColor="#6E473B"
                    android:lineSpacingExtra="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0C4B4"
                    android:layout_marginVertical="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="TOTAL"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#291C0E"/>

                    <TextView
                        android:id="@+id/tv_checkout_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.000 TND"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#6E473B"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARTE : Infos livraison -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚚  Infos de livraison"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#291C0E"
                    android:layout_marginBottom="16dp"/>

                <!-- Téléphone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÉLÉPHONE"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_checkout_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:errorTextColor="#B00020">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_checkout_phone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="+216 XX XXX XXX"
                        android:inputType="phone"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Adresse -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADRESSE DE LIVRAISON"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_checkout_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:errorTextColor="#B00020">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_checkout_address"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:hint="Ex: 12 rue Habib Bourguiba, Tunis"
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Note -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTE / REMARQUE (optionnel)"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_checkout_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_checkout_note"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:hint="Sans oignons, sonnez 2 fois..."
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Bouton confirmer -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_confirm_order"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp"
                    android:text="✅  Confirmer la commande"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E1D4C2"
                    app:backgroundTint="#6E473B"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>