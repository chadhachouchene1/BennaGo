<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_login_hero"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#E1D4C2"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒  Mon Panier"
                android:textColor="#E1D4C2"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_cart_item_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 article(s)"
                android:textColor="#A78D78"
                android:textSize="13sp"/>
        </LinearLayout>

        <View android:layout_width="40dp" android:layout_height="40dp"/>
    </LinearLayout>

    <!-- LISTE DES ARTICLES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_cart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="110dp"
        android:layout_marginBottom="160dp"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- MESSAGE VIDE -->
    <TextView
        android:id="@+id/tv_cart_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="240dp"
        android:text="Votre panier est vide 🛒\nAjoutez des plats depuis le menu"
        android:textColor="#A78D78"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:visibility="gone"/>

    <!-- FOOTER : total + bouton commander -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#F5EFE6">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_cart_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total : 0.000 TND"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#291C0E"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_checkout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="→  Valider la commande"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#E1D4C2"
                app:backgroundTint="#6E473B"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>