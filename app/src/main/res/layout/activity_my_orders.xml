<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E1D4C2">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_login_hero"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#E1D4C2"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋  Mes Commandes"
                android:textColor="#E1D4C2"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_order_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 commande(s)"
                android:textColor="#A78D78"
                android:textSize="12sp"/>
        </LinearLayout>

        <View android:layout_width="40dp" android:layout_height="40dp"/>
    </LinearLayout>

    <!-- ✅ FIX : id = layout_orders_empty (LinearLayout, pas TextView) -->
    <LinearLayout
        android:id="@+id/layout_orders_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦"
            android:textSize="64sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aucune commande pour le moment"
            android:textColor="#6E473B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parcourez le menu et passez votre première commande !"
            android:textColor="#A78D78"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="32dp"/>

    </LinearLayout>

    <!-- LISTE COMMANDES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_orders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:visibility="gone"/>

</LinearLayout>