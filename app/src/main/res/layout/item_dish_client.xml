<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- ── Image du plat avec coins arrondis ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EDE4D8">

            <ImageView
                android:id="@+id/iv_dish_client"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:srcCompat="@android:drawable/ic_menu_gallery"/>

        </androidx.cardview.widget.CardView>

        <!-- ── Infos plat ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Nom -->
            <TextView
                android:id="@+id/tv_client_dish_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom du plat"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#291C0E"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Badge catégorie -->
            <TextView
                android:id="@+id/tv_client_dish_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catégorie"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6E473B"
                android:background="#22A78D78"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="5dp"
                android:letterSpacing="0.05"/>

            <!-- Description -->
            <TextView
                android:id="@+id/tv_client_dish_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#A78D78"
                android:layout_marginTop="5dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"/>

            <!-- Ligne prix + bouton ajouter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- Prix -->
                <TextView
                    android:id="@+id/tv_client_dish_price"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="0.000 TND"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#6E473B"/>

                <!-- ✅ MaterialButton à la place du TextView -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_to_cart"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F2EBE0"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Ajouter au panier"
                    app:backgroundTint="#6E473B"
                    app:cornerRadius="18dp"
                    app:elevation="2dp"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>