<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp">

        <!-- ── HERO brun foncé ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_login_hero"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- Logo cercle beige -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#E1D4C2">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:text="🥘"
                        android:textSize="30sp"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="BennaGO"
                android:textColor="#E1D4C2"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Commandez. Régalez-vous."
                android:textColor="#A78D78"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- ── CARTE FORMULAIRE ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="-28dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- ── TABS : Utilisateur / Inscription (2 onglets seulement) ── -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_tab_container"
                    app:tabBackground="@drawable/bg_tab_item"
                    app:tabSelectedTextColor="#E1D4C2"
                    app:tabTextColor="#6E473B"
                    app:tabRippleColor="@android:color/transparent"
                    app:tabGravity="fill"
                    app:tabMode="fixed"
                    app:tabIndicatorHeight="0dp"
                    app:tabPaddingStart="0dp"
                    app:tabPaddingEnd="0dp"
                    style="@style/Widget.Material3.TabLayout"/>

                <!-- ── EMAIL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="EMAIL"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="votre@email.com"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── MOT DE PASSE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="MOT DE PASSE"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:passwordToggleEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── CODE ADMIN — caché, apparaît au long press ── -->
                <TextView
                    android:id="@+id/tv_label_admin_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="CODE SECRET ADMIN"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:visibility="gone"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_admin_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#291C0E"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_menu_manage"
                    app:startIconTint="#291C0E"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_admin_code"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Code secret admin"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── BOUTON (long press = mode admin) ── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="→  Se connecter"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E1D4C2"
                    android:letterSpacing="0.02"
                    android:longClickable="true"
                    app:backgroundTint="#6E473B"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"/>

                <!-- ── ERREUR GLOBALE ── -->
                <TextView
                    android:id="@+id/tv_error_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text=""
                    android:textColor="#B00020"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:visibility="gone"/>

                <!-- ── LIEN INSCRIPTION ── -->
                <TextView
                    android:id="@+id/tv_register_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp"
                    android:text="Pas encore de compte ? S'inscrire"
                    android:textColor="#6E473B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>