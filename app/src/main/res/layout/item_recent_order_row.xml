<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:paddingHorizontal="4dp"
    android:background="?attr/selectableItemBackground">

    <!-- Icône commande -->
    <TextView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="📋"
        android:textSize="18sp"
        android:gravity="center"
        android:background="#FFE8D5C0"/>

    <!-- Infos commande -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- ID + Client -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_recent_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#291C0E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ·  "
                android:textSize="13sp"
                android:textColor="#A78D78"/>

            <TextView
                android:id="@+id/tv_recent_order_client"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Client"
                android:textSize="13sp"
                android:textColor="#291C0E"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Total + Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_recent_order_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.000 TND"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6E473B"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tv_recent_order_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00/00 00:00"
                android:textSize="11sp"
                android:textColor="#A78D78"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Badge statut -->
    <TextView
        android:id="@+id/tv_recent_order_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="En attente"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#D4703A"
        android:background="#22D4703A"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"/>

</LinearLayout>