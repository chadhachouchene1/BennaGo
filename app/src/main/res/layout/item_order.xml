<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F5EFE6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Ligne 1 : ID + Statut + Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#291C0E"/>

            <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp"/>

            <TextView
                android:id="@+id/tv_order_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00/00 00:00"
                android:textSize="11sp"
                android:textColor="#A78D78"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En attente"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#D4703A"
                android:background="#22D4703A"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EDE4D8" android:layout_marginBottom="8dp"/>

        <!-- Ligne 2 : Client + Téléphone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 "
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_order_client"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Client"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#291C0E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 "
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_order_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="13sp"
                android:textColor="#6E473B"/>
        </LinearLayout>

        <!-- Adresse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 "
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_order_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adresse"
                android:textSize="12sp"
                android:textColor="#A78D78"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Ligne 3 : Total + Bouton statut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_order_total"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="0.000 TND"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#6E473B"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_change_status"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Changer statut"
                android:textSize="12sp"
                android:textColor="#6E473B"
                app:strokeColor="#6E473B"
                app:cornerRadius="8dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>