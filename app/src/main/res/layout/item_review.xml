<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne 1 : Avatar + Nom + Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Avatar lettre -->
            <TextView
                android:id="@+id/tv_review_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="U"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/circle_orange_transparent"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_review_client_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom Client"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#291C0E"/>

                <TextView
                    android:id="@+id/tv_review_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/01/2026"
                    android:textSize="11sp"
                    android:textColor="#A78D78"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Badge note -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FFF5EDE8"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_review_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#6E473B"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/5"
                    android:textSize="11sp"
                    android:textColor="#A78D78"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0EAE0"
            android:layout_marginBottom="10dp"/>

        <!-- Étoiles visuelles -->
        <TextView
            android:id="@+id/tv_review_stars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★★★★★"
            android:textSize="18sp"
            android:textColor="#D0B88A"
            android:layout_marginBottom="8dp"/>

        <!-- Commentaire -->
        <TextView
            android:id="@+id/tv_review_comment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Commentaire du client..."
            android:textSize="13sp"
            android:textColor="#5C4A3A"
            android:lineSpacingExtra="4dp"
            android:fontFamily="sans-serif"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>