<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2EBE0">

    <!-- ══════════════════════════════════════════════
         HEADER FIXE
         ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/header_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_login_hero"
        android:paddingTop="36dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp"
        android:elevation="6dp">

        <!-- Ligne 1 : Salutation + Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bonjour 👋"
                    android:textSize="13sp"
                    android:textColor="#CCBFAF"
                    android:letterSpacing="0.03"/>

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilisateur"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#F2EBE0"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Avatar → Profil -->
            <FrameLayout
                android:id="@+id/iv_avatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/circle_orange_transparent">

                <TextView
                    android:id="@+id/tv_avatar_letter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="U"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#F2EBE0"
                    android:gravity="center"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ✅ Ligne 2 : Barre de recherche FONCTIONNELLE avec EditText -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="16sp"/>

                <!-- ✅ EditText fonctionnel -->
                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:hint="Rechercher un plat..."
                    android:textSize="14sp"
                    android:textColor="#291C0E"
                    android:textColorHint="#A78D78"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:maxLines="1"/>

                <!-- ✅ Bouton effacer la recherche -->
                <TextView
                    android:id="@+id/btn_clear_search"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="✕"
                    android:textSize="14sp"
                    android:textColor="#A78D78"
                    android:gravity="center"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         CONTENU SCROLLABLE
         ══════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="170dp"
        android:layout_marginBottom="64dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- ✅ Bannière REMISE sur les plats (remplace "livraison offerte") -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_promo"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#6E473B">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Badge remise -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="#44FFFFFF"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏷️  REMISE SPÉCIALE"
                                android:textSize="10sp"
                                android:textColor="#F2EBE0"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_promo_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-15% sur tous\nles plats du jour !"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F2EBE0"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>

                    <!-- Pourcentage remise mis en avant -->
                    <LinearLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#44FFFFFF">

                        <TextView
                            android:id="@+id/tv_promo_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-15%"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#F2EBE0"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TODAY"
                            android:textSize="9sp"
                            android:textColor="#CCBFAF"
                            android:gravity="center"
                            android:letterSpacing="0.1"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Titre Catégories (caché pendant la recherche) ── -->
            <TextView
                android:id="@+id/tv_categories_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catégories"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#291C0E"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <!-- ── Chips filtre (cachés pendant la recherche) ── -->
            <HorizontalScrollView
                android:id="@+id/scroll_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chip_all"
                        android:layout_width="wrap_content" android:layout_height="38dp"
                        android:text="✨ Tous" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#F2EBE0" android:gravity="center"
                        android:background="@color/brown_dark"
                        android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chip_burger"
                        android:layout_width="wrap_content" android:layout_height="38dp"
                        android:text="🍔 Burgers" android:textSize="13sp"
                        android:textColor="#6E473B" android:gravity="center"
                        android:background="#FFEADFD8"
                        android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chip_pizza"
                        android:layout_width="wrap_content" android:layout_height="38dp"
                        android:text="🍕 Pizzas" android:textSize="13sp"
                        android:textColor="#6E473B" android:gravity="center"
                        android:background="#FFEADFD8"
                        android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chip_sandwich"
                        android:layout_width="wrap_content" android:layout_height="38dp"
                        android:text="🥪 Sandwichs" android:textSize="13sp"
                        android:textColor="#6E473B" android:gravity="center"
                        android:background="#FFEADFD8"
                        android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chip_dessert"
                        android:layout_width="wrap_content" android:layout_height="38dp"
                        android:text="🍰 Desserts" android:textSize="13sp"
                        android:textColor="#6E473B" android:gravity="center"
                        android:background="#FFEADFD8"
                        android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chip_boisson"
                        android:layout_width="wrap_content" android:layout_height="38dp"
                        android:text="🥤 Boissons" android:textSize="13sp"
                        android:textColor="#6E473B" android:gravity="center"
                        android:background="#FFEADFD8"
                        android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── Titre Notre Menu / Résultats recherche ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tv_menu_title"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Notre Menu"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#291C0E"/>

                <TextView
                    android:id="@+id/tv_dish_count_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#A78D78"/>
            </LinearLayout>

            <!-- Message vide -->
            <TextView
                android:id="@+id/tv_menu_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aucun plat trouvé."
                android:textColor="#A78D78"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="gone"/>

            <!-- RecyclerView plats -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════
         BOTTOM NAVIGATION
         ══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:elevation="10dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#FFFFFF"
            app:menu="@menu/bottom_nav_user"
            app:itemIconTint="@color/brown_medium"
            app:itemTextColor="@color/brown_medium"
            app:labelVisibilityMode="labeled"/>

        <TextView
            android:id="@+id/tv_cart_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="96dp"
            android:layout_marginTop="4dp"
            android:text="0"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#FFB00020"
            android:visibility="gone"/>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>