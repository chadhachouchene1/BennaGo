<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp">

        <!-- ══════════════════════════════
             HERO brun foncé (même style que login)
             ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_login_hero"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- Cercle emoji 🍽️ -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#E1D4C2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🍲"
                        android:textSize="40sp"/>

                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Créer un compte"
                android:textColor="#E1D4C2"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <!-- Sous-titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rejoignez BennaGO !"
                android:textColor="#A78D78"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- ══════════════════════════════
             CARTE FORMULAIRE flottante
             ══════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="-28dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- ── NOM COMPLET ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOM COMPLET"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Votre nom complet"
                        android:inputType="textPersonName"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── EMAIL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EMAIL"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="votre@email.com"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── TÉLÉPHONE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="TÉLÉPHONE"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_menu_call"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="+216 XX XXX XXX"
                        android:inputType="phone"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── MOT DE PASSE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="MOT DE PASSE"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:passwordToggleEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Minimum 8 caractères"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── CONFIRMER MOT DE PASSE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="CONFIRMER MOT DE PASSE"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:passwordToggleEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#6E473B"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Répétez le mot de passe"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── BOUTON S'INSCRIRE ── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="→  S'inscrire"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E1D4C2"
                    android:letterSpacing="0.02"
                    app:backgroundTint="#6E473B"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"/>

                <!-- ── LIEN RETOUR LOGIN ── -->
                <TextView
                    android:id="@+id/tv_login_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp"
                    android:text="Déjà un compte ? Se connecter"
                    android:textColor="#6E473B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>