<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F5EFE6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne 1 : ID + Icône statut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_my_order_id"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Commande #1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#291C0E"/>

            <!-- Icône statut -->
            <TextView
                android:id="@+id/tv_my_order_status_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⏳"
                android:textSize="18sp"
                android:gravity="center"
                android:background="#EDE4D8"
                android:layout_marginEnd="8dp"/>

            <!-- Badge statut -->
            <TextView
                android:id="@+id/tv_my_order_status_bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="1dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_my_order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En attente"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#D4703A"
                android:background="#22D4703A"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EDE4D8"
            android:layout_marginBottom="10dp"/>

        <!-- Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 "
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_my_order_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2026  12:00"
                android:textSize="13sp"
                android:textColor="#A78D78"/>
        </LinearLayout>

        <!-- Adresse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 "
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_my_order_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adresse de livraison"
                android:textSize="13sp"
                android:textColor="#6E473B"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EDE4D8"
            android:layout_marginBottom="10dp"/>

        <!-- Ligne bas : Total + Voir détails -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL"
                    android:textSize="11sp"
                    android:textColor="#A78D78"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_my_order_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.000 TND"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#6E473B"/>
            </LinearLayout>

            <!-- Bouton voir détail -->
            <TextView
                android:id="@+id/tv_my_order_detail"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Voir le détail →"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#E1D4C2"
                android:gravity="center"
                android:background="#6E473B"
                android:paddingHorizontal="16dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>