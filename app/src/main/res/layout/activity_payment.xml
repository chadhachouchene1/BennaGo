<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_login_hero"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#E1D4C2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="💳  Paiement"
                android:textColor="#E1D4C2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View android:layout_width="40dp" android:layout_height="40dp"/>
        </LinearLayout>

        <!-- TOTAL -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Montant à payer"
                    android:textSize="13sp"
                    android:textColor="#A78D78"/>

                <TextView
                    android:id="@+id/tv_payment_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.000 TND"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="#6E473B"/>

                <TextView
                    android:id="@+id/tv_selected_method"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#5A9E6F"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MÉTHODES : Livraison + Espèces                      -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_payment_methods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Méthode de paiement"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#291C0E"
                android:layout_marginBottom="12dp"/>

            <!-- Livraison (carte bancaire Stripe) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_livraison"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#F5EFE6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🚚"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:background="#EDE4D8"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Livraison"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#291C0E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paiement sécurisé par carte · Stripe"
                            android:textSize="11sp"
                            android:textColor="#A78D78"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="#6E473B"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Espèces -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_cash"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#F5EFE6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="💵"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:background="#EDE4D8"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Espèces"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#291C0E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paiement à la livraison"
                            android:textSize="11sp"
                            android:textColor="#A78D78"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="#6E473B"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- FORMULAIRE CARTE (visible quand Livraison sélectionné) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_carte_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <!-- Prévisualisation carte -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FF291C0E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BennaGO" android:textColor="#E1D4C2"
                            android:textSize="15sp" android:textStyle="bold" android:layout_weight="1"/>
                        <TextView android:id="@+id/tv_card_type"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="" android:textColor="#E1D4C2" android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="38dp" android:layout_height="26dp"
                        android:layout_marginTop="14dp" android:background="#FFD4A843"/>

                    <TextView android:id="@+id/tv_card_preview_number"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="••••  ••••  ••••  ••••"
                        android:textColor="#FFFFFF" android:textSize="17sp"
                        android:letterSpacing="0.06" android:layout_marginTop="12dp"
                        android:fontFamily="monospace"/>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="10dp">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TITULAIRE" android:textColor="#A78D78"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tv_card_preview_holder"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TITULAIRE" android:textColor="#FFFFFF"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="EXPIRE" android:textColor="#A78D78"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tv_card_preview_expiry"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MM/AA" android:textColor="#FFFFFF"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Numéro carte -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_card_number"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" android:hint="Numéro de carte"
                app:boxBackgroundColor="#F5EFE6" app:boxStrokeColor="#A78D78"
                app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                app:errorTextColor="#B00020">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_card_number"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:inputType="number" android:maxLength="19"
                    android:textSize="16sp" android:textColor="#291C0E"
                    android:fontFamily="monospace"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Titulaire -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_card_holder"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" android:hint="Nom du titulaire"
                app:boxBackgroundColor="#F5EFE6" app:boxStrokeColor="#A78D78"
                app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                app:errorTextColor="#B00020">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_card_holder"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:inputType="textCapWords"
                    android:textSize="14sp" android:textColor="#291C0E"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Expiry + CVV -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:weightSum="2">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_expiry"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:layout_marginEnd="6dp"
                    android:hint="MM/AA"
                    app:boxBackgroundColor="#F5EFE6" app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                    app:errorTextColor="#B00020">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_expiry"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:inputType="number" android:maxLength="5"
                        android:textSize="14sp" android:textColor="#291C0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_cvv"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:layout_marginStart="6dp"
                    android:hint="CVV"
                    app:boxBackgroundColor="#F5EFE6" app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                    app:errorTextColor="#B00020"
                    app:passwordToggleEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_cvv"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:inputType="numberPassword" android:maxLength="4"
                        android:textSize="14sp" android:textColor="#291C0E"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="🔒 Paiement sécurisé via Stripe"
                android:textSize="11sp"
                android:textColor="#A78D78"/>
        </LinearLayout>

        <!-- INFO ESPÈCES -->
        <LinearLayout
            android:id="@+id/layout_cash_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="#F5EFE6"
            android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💵  Paiement à la livraison"
                android:textSize="15sp" android:textStyle="bold" android:textColor="#291C0E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Le livreur collectera le montant exact lors de la livraison. Préparez l'appoint si possible."
                android:textSize="13sp" android:textColor="#6E473B"
                android:layout_marginTop="8dp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <!-- BOUTON PAYER -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pay_now"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:text="Choisissez une méthode"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#E1D4C2"
            app:backgroundTint="#6E473B"
            app:cornerRadius="14dp"/>

        <!-- ÉCRAN TRAITEMENT -->
        <LinearLayout
            android:id="@+id/layout_processing"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <ProgressBar
                android:id="@+id/progress_payment"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:indeterminateTint="#6E473B"/>

            <TextView
                android:id="@+id/tv_processing_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initialisation..."
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#291C0E"
                android:gravity="center"
                android:layout_marginTop="20dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>