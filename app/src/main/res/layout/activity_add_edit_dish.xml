<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_login_hero"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#E1D4C2"/>

            <TextView
                android:id="@+id/tv_form_title"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Ajouter un plat"
                android:textColor="#E1D4C2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View android:layout_width="40dp" android:layout_height="40dp"/>

        </LinearLayout>

        <!-- CARTE FORMULAIRE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- IMAGE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMAGE DU PLAT"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/iv_image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="8dp"
                    android:background="#EDE4D8"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:hint="Appuyez pour choisir une image"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="Appuyez sur l'image pour en choisir une"
                    android:textColor="#A78D78"
                    android:textSize="11sp"/>

                <!-- NOM -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="NOM DU PLAT"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_dish_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:errorTextColor="#B00020">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_dish_name"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="ex: Double Beef Burger"
                        android:textColor="#291C0E"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PRIX -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="PRIX (TND)"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_dish_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:errorTextColor="#B00020">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_dish_price"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="ex: 12.500"
                        android:inputType="numberDecimal"
                        android:textColor="#291C0E"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- CATÉGORIE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="CATÉGORIE"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_dish_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    app:errorTextColor="#B00020">
                    <AutoCompleteTextView
                        android:id="@+id/ac_dish_category"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Choisir une catégorie"
                        android:textColor="#291C0E"
                        android:textSize="14sp"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- DESCRIPTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="DESCRIPTION"
                    android:textColor="#A78D78"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_dish_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="#EDE4D8"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:errorTextColor="#B00020">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_dish_description"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:hint="Description courte..."
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:textColor="#291C0E"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- SWITCH ACTIF -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:background="#EDE4D8"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Plat visible par les clients"
                        android:textColor="#291C0E"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <Switch
                        android:id="@+id/switch_dish_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#6E473B"
                        android:trackTint="#A78D78"/>

                </LinearLayout>

                <!-- BOUTON SAUVEGARDER -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_dish"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="→  Ajouter au menu"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E1D4C2"
                    app:backgroundTint="#6E473B"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>