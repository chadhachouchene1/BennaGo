<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_light"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- HEADER  — fond courbe marron foncé                      -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <View
            android:id="@+id/header_bg"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/header_curve_brown"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Bouton logout (coin haut droite) -->
        <ImageButton
            android:id="@+id/btn_logout_admin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/circle_orange_transparent"
            android:src="@drawable/ic_logout"
            android:contentDescription="Déconnexion"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/white" />

        <!-- Badge "ADMIN" -->
        <TextView
            android:id="@+id/tv_admin_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  🔧 ADMIN  "
            android:textSize="11sp"
            android:textColor="@color/brown_dark"
            android:textStyle="bold"
            android:background="#FFE8B86D"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="0dp"/>

        <!-- Icône chef -->
        <TextView
            android:id="@+id/tv_admin_emoji"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="👨‍🍳"
            android:textSize="38sp"
            android:gravity="center"
            android:background="@drawable/circle_orange_transparent"
            android:layout_marginTop="52dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Titre admin -->
        <TextView
            android:id="@+id/tv_admin_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tableau de bord Admin"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_emoji"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_admin_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gérez votre restaurant"
            android:textSize="13sp"
            android:textColor="@color/beige_medium"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- STATS CARD  — chevauche le header                       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_stats_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="200dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Statistiques du jour"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/brown_dark"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:weightSum="3">

                    <!-- Stat 1 : Utilisateurs -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFF5EDE8"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="22sp"
                            android:gravity="center"/>

                        <TextView
                            android:id="@+id/tv_total_users"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clients"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"/>
                    </LinearLayout>

                    <!-- Séparateur -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#FFE8D5C0"
                        android:layout_marginHorizontal="4dp"/>

                    <!-- Stat 2 : Commandes -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFF0E5"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋"
                            android:textSize="22sp"
                            android:gravity="center"/>

                        <TextView
                            android:id="@+id/tv_total_orders"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/orange_primary"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Commandes"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"/>
                    </LinearLayout>

                    <!-- Séparateur -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#FFE8D5C0"
                        android:layout_marginHorizontal="4dp"/>

                    <!-- Stat 3 : Plats -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFEFFFB"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍽️"
                            android:textSize="22sp"
                            android:gravity="center"/>

                        <TextView
                            android:id="@+id/tv_total_dishes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#5A9E6F"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plats"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TITRE DE SECTION : Actions rapides                      -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tv_section_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actions rapides"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/brown_dark"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/card_stats_summary"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- GRILLE DES CARTES D'ACTION (2 colonnes)                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/grid_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_actions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Ligne 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- Carte Gérer le Menu -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_manage_menu"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <!-- Icône avec fond coloré rond -->
                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="🍽️"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_orange_transparent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gérer le Menu"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:layout_marginTop="10dp"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ajouter, modifier"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Carte Commandes -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_manage_orders"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFF0E5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="📋"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_orange_transparent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Commandes"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:layout_marginTop="10dp"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Voir &amp; confirmer"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Ligne 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- Carte Utilisateurs -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_manage_users"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFF5EDE8">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="👥"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_orange_transparent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clients"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:layout_marginTop="10dp"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gérer les comptes"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Carte Statistiques -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_stats"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFEFFFB">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="📊"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_orange_transparent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Statistiques"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:layout_marginTop="10dp"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rapports &amp; chiffres"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Ligne 3 : Notifications + Avis (pleine largeur) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- Carte Notifications -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_notifications"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFF9F2FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="🔔"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_orange_transparent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notifications"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:layout_marginTop="10dp"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Envoyer alertes"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Carte Avis -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_reviews"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFBED">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="⭐"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_orange_transparent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avis Clients"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"
                            android:layout_marginTop="10dp"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lire les retours"
                            android:textSize="11sp"
                            android:textColor="@color/brown_medium"
                            android:gravity="center"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SECTION : Commandes récentes                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tv_section_recent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Commandes récentes"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/brown_dark"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/grid_actions"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Carte commandes récentes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_recent_orders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/tv_section_recent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Ligne commande exemple 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🍔"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/circle_orange_transparent"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Commande #001"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Double Beef + Frites"
                            android:textSize="12sp"
                            android:textColor="@color/brown_medium"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="En attente"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/orange_primary"
                        android:background="#22FF8C42"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FFE8D5C0"/>

                <!-- Ligne commande exemple 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🍕"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/circle_orange_transparent"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Commande #002"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown_dark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pizza Margherita"
                            android:textSize="12sp"
                            android:textColor="@color/brown_medium"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Livré ✓"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#5A9E6F"
                        android:background="#225A9E6F"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <!-- Bouton Voir toutes -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_see_all_orders"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="Voir toutes les commandes →"
                    android:textSize="13sp"
                    android:textColor="@color/orange_primary"
                    app:strokeColor="@color/orange_primary"
                    app:cornerRadius="10dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Espace en bas -->
        <View
            android:id="@+id/bottom_spacer"
            android:layout_width="match_parent"
