<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1D4C2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_login_hero"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#E1D4C2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📊  Statistiques"
                android:textColor="#E1D4C2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View android:layout_width="40dp" android:layout_height="40dp"/>
        </LinearLayout>

        <!-- CARTE : Chiffres clés -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chiffres clés"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#291C0E"
                    android:layout_marginBottom="16dp"/>

                <!-- Ligne 1 : Clients + Plats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="90dp" android:layout_marginEnd="6dp"
                        android:orientation="vertical" android:gravity="center"
                        android:background="#EDE4D8">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👥" android:textSize="24sp"/>
                        <TextView android:id="@+id/tv_stat_users"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#291C0E" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Clients" android:textSize="12sp" android:textColor="#A78D78"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="90dp" android:layout_marginStart="6dp"
                        android:orientation="vertical" android:gravity="center"
                        android:background="#EDE4D8">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🍽️" android:textSize="24sp"/>
                        <TextView android:id="@+id/tv_stat_dishes"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#291C0E" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Plats actifs" android:textSize="12sp" android:textColor="#A78D78"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Ligne 2 : Commandes + Revenus -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="90dp" android:layout_marginEnd="6dp"
                        android:orientation="vertical" android:gravity="center"
                        android:background="#EDE4D8">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋" android:textSize="24sp"/>
                        <TextView android:id="@+id/tv_stat_orders"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#6E473B" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Commandes" android:textSize="12sp" android:textColor="#A78D78"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="90dp" android:layout_marginStart="6dp"
                        android:orientation="vertical" android:gravity="center"
                        android:background="#EDE4D8">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰" android:textSize="24sp"/>
                        <TextView android:id="@+id/tv_stat_revenue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="#5A9E6F" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Revenus (TND)" android:textSize="12sp" android:textColor="#A78D78"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARTE : Commandes en attente -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFF0E5">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:padding="20dp">

                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⏳  Commandes en attente"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#291C0E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="À traiter maintenant" android:textSize="12sp"
                        android:textColor="#A78D78" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_pending_orders"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="36sp" android:textStyle="bold"
                    android:textColor="#D4703A"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARTE : Top 3 plats (données réelles) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏆  Plats les plus commandés"
                    android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#291C0E" android:layout_marginBottom="12dp"/>

                <!-- Top 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="#EDE4D8" android:padding="12dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="🥇" android:textSize="20sp"/>
                    <TextView android:id="@+id/tv_top1_name"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="--"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="#291C0E" android:layout_marginStart="10dp"/>
                    <TextView android:id="@+id/tv_top1_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#6E473B"/>
                </LinearLayout>

                <!-- Top 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:padding="12dp" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="🥈" android:textSize="20sp"/>
                    <TextView android:id="@+id/tv_top2_name"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="--"
                        android:textSize="14sp" android:textColor="#291C0E"
                        android:layout_marginStart="10dp"/>
                    <TextView android:id="@+id/tv_top2_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="13sp" android:textColor="#6E473B"/>
                </LinearLayout>

                <!-- Top 3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:padding="12dp">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="🥉" android:textSize="20sp"/>
                    <TextView android:id="@+id/tv_top3_name"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="--"
                        android:textSize="14sp" android:textColor="#291C0E"
                        android:layout_marginStart="10dp"/>
                    <TextView android:id="@+id/tv_top3_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="13sp" android:textColor="#6E473B"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARTE : Plats par catégorie -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🍔  Plats par catégorie"
                    android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#291C0E" android:layout_marginBottom="16dp"/>

                <!-- Burger -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="🍔 Burger" android:textSize="13sp" android:textColor="#291C0E"/>
                    <View android:id="@+id/bar_burger" android:layout_width="4dp"
                        android:layout_height="16dp" android:background="#6E473B"/>
                    <TextView android:id="@+id/tv_count_burger" android:layout_width="30dp"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="12sp" android:textColor="#6E473B"
                        android:gravity="end" android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Pizza -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="🍕 Pizza" android:textSize="13sp" android:textColor="#291C0E"/>
                    <View android:id="@+id/bar_pizza" android:layout_width="4dp"
                        android:layout_height="16dp" android:background="#A78D78"/>
                    <TextView android:id="@+id/tv_count_pizza" android:layout_width="30dp"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="12sp" android:textColor="#6E473B"
                        android:gravity="end" android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Boisson -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="🥤 Boisson" android:textSize="13sp" android:textColor="#291C0E"/>
                    <View android:id="@+id/bar_boisson" android:layout_width="4dp"
                        android:layout_height="16dp" android:background="#291C0E"/>
                    <TextView android:id="@+id/tv_count_boisson" android:layout_width="30dp"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="12sp" android:textColor="#6E473B"
                        android:gravity="end" android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Autre -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="🍽️ Autre" android:textSize="13sp" android:textColor="#291C0E"/>
                    <View android:id="@+id/bar_autre" android:layout_width="4dp"
                        android:layout_height="16dp" android:background="#EDE4D8"/>
                    <TextView android:id="@+id/tv_count_autre" android:layout_width="30dp"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="12sp" android:textColor="#6E473B"
                        android:gravity="end" android:layout_marginStart="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARTE : Nouveaux clients -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F5EFE6">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="20dp">

                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👤  Total clients inscrits"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#291C0E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Comptes actifs" android:textSize="12sp"
                        android:textColor="#A78D78" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_new_users_week"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="36sp" android:textStyle="bold"
                    android:textColor="#5A9E6F"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>