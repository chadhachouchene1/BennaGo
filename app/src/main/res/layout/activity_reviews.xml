<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2EBE0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_login_hero"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#F2EBE0"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="⭐  Donner mon avis"
                android:textColor="#F2EBE0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View android:layout_width="40dp" android:layout_height="40dp"/>
        </LinearLayout>

        <!-- CARTE : Formulaire avis -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Titre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Votre expérience compte !"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#291C0E"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aidez-nous à améliorer notre service"
                    android:textSize="12sp"
                    android:textColor="#A78D78"
                    android:layout_marginBottom="20dp"/>

                <!-- ── NOTE avec étoiles ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTE"
                    android:textColor="#A78D78"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- 5 étoiles cliquables -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/star_1"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="☆"
                        android:textSize="32sp"
                        android:textColor="#D0B88A"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/star_2"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="☆"
                        android:textSize="32sp"
                        android:textColor="#D0B88A"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/star_3"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="☆"
                        android:textSize="32sp"
                        android:textColor="#D0B88A"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/star_4"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="☆"
                        android:textSize="32sp"
                        android:textColor="#D0B88A"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/star_5"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="☆"
                        android:textSize="32sp"
                        android:textColor="#D0B88A"
                        android:gravity="center"/>

                </LinearLayout>

                <!-- ── COMMENTAIRE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMMENTAIRE"
                    android:textColor="#A78D78"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_review_comment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="#F5EFE6"
                    app:boxStrokeColor="#A78D78"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:errorTextColor="#B00020">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_review_comment"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:hint="Partagez votre expérience..."
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:textSize="14sp"
                        android:textColor="#291C0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Bouton envoyer -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_review"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="⭐  Envoyer mon avis"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6E473B"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARTE : Mes avis précédents -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mes avis précédents"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#291C0E"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_my_reviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"/>

        <TextView
            android:id="@+id/tv_no_reviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vous n'avez pas encore donné d'avis"
            android:textColor="#A78D78"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>