<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F5EFE6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Image du plat -->
        <ImageView
            android:id="@+id/iv_dish_client"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="#EDE4D8"/>

        <!-- Infos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_dish_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom du plat"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#291C0E"/>

            <TextView
                android:id="@+id/tv_dish_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catégorie"
                android:textSize="12sp"
                android:textColor="#A78D78"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tv_dish_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 TND"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#6E473B"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Actions à droite -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Switch Actif/Inactif -->
            <Switch
                android:id="@+id/switch_active"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#6E473B"
                android:trackTint="#A78D78"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <!-- Modifier -->
                <ImageButton
                    android:id="@+id/btn_edit_dish"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_edit"
                    android:tint="#6E473B"
                    android:padding="4dp"/>

                <!-- Supprimer -->
                <ImageButton
                    android:id="@+id/btn_delete_dish"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_delete"
                    android:tint="#B00020"
                    android:padding="4dp"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>